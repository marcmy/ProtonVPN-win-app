<UserControl x:Class="ProtonVPN.Client.UI.Controls.ExcludableLocationSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:custom="using:ProtonVPN.Client.Common.UI.Controls.Custom"
             xmlns:pathicons="using:ProtonVPN.Client.Common.UI.Assets.Icons.PathIcons"
             xmlns:controls="using:ProtonVPN.Client.UI.Controls"
             xmlns:selectors="using:ProtonVPN.Client.Selectors"
             xmlns:exclusion="using:ProtonVPN.Client.Models.Features.LocationExclusion"
             x:DefaultBindMode="OneWay">

    <UserControl.Resources>
        
        <GridLength x:Key="IconColumnWidth">24</GridLength>

        <Style x:Key="LocationItemButtonStyle"
               BasedOn="{StaticResource RowButtonStyle}"
               TargetType="Button">
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="10,4" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Left" />
            <Setter Property="CornerRadius"
                    Value="4" />
        </Style>

        <DataTemplate x:Key="LocationGroupTemplate"
                      x:DataType="exclusion:ExcludableLocationGroup">

            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       IsTabStop="False"
                       Margin="8,0,0,0"
                       Foreground="{ThemeResource TextWeakColorBrush}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Text="{x:Bind DisplayName}"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap" />

        </DataTemplate>

        <DataTemplate x:Key="CountryLocationTemplate"
                      x:DataType="exclusion:ExcludableCountryItem">
            <Button Command="{x:Bind ExcludeLocationCommand, Mode=OneTime}"
                    Style="{StaticResource LocationItemButtonStyle}">
                <Grid ColumnSpacing="12"
                      Margin="0,-84">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{StaticResource IconColumnWidth}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <custom:SimpleCountryFlag Grid.Column="0"
                                              Width="{StaticResource MainFlagWidth}"
                                              Height="{StaticResource MainFlagHeight}"
                                              VerticalAlignment="Center"
                                              CountryCode="{x:Bind CountryCode}"
                                              FlagType="Country" />

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="{x:Bind DisplayName}"
                               Foreground="{ThemeResource TextNormColorBrush}"
                               Style="{StaticResource BodyTextBlockStyle}" />
                </Grid>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="StateLocationTemplate"
                      x:DataType="exclusion:ExcludableStateItem">
            <Button Command="{x:Bind ExcludeLocationCommand, Mode=OneTime}"
                    Style="{StaticResource LocationItemButtonStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{StaticResource IconColumnWidth}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <pathicons:MapPin Grid.Column="0"
                                      Size="Pixels20"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource TextNormColorBrush}" />

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="{x:Bind DisplayName}"
                               Foreground="{ThemeResource TextNormColorBrush}"
                               Style="{StaticResource BodyTextBlockStyle}" />
                </Grid>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="CityLocationTemplate"
                      x:DataType="exclusion:ExcludableCityItem">
            <Button Command="{x:Bind ExcludeLocationCommand, Mode=OneTime}"
                    Style="{StaticResource LocationItemButtonStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{StaticResource IconColumnWidth}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <pathicons:MapPin Grid.Column="0"
                                      Size="Pixels20"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource TextNormColorBrush}" />

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="{x:Bind DisplayName}"
                               Foreground="{ThemeResource TextNormColorBrush}"
                               Style="{StaticResource BodyTextBlockStyle}" />
                </Grid>
            </Button>
        </DataTemplate>

        <selectors:ExcludableLocationItemTemplateSelector x:Key="ExcludableLocationItemTemplateSelector"
                                                          LocationGroupTemplate="{StaticResource LocationGroupTemplate}"
                                                          CountryLocationTemplate="{StaticResource CountryLocationTemplate}"
                                                          StateLocationTemplate="{StaticResource StateLocationTemplate}"
                                                          CityLocationTemplate="{StaticResource CityLocationTemplate}" />
    </UserControl.Resources>

    <custom:GhostButton x:Name="SelectorButton"
                        Padding="5,3"
                        Content="{x:Bind PlaceholderText}"
                        FontWeight="{ThemeResource BodyFontWeight}"
                        Background="{ThemeResource InteractionDefaultColorBrush}"
                        Click="OnSelectorButtonClick">
        <custom:GhostButton.RightIcon>
            <pathicons:ChevronTinyDown Size="Pixels16"
                                       Foreground="{ThemeResource TextNormColorBrush}" />
        </custom:GhostButton.RightIcon>
        <FlyoutBase.AttachedFlyout>
            <Flyout x:Name="LocationFlyout"
                    Placement="BottomEdgeAlignedRight"
                    Closed="OnFlyoutClosed">

                <StackPanel Width="300"
                            Padding="4"
                            Spacing="8">

                    <TextBox x:Name="SearchTextBox"
                             AutomationProperties.AutomationId="ExcludedLocationSearchTextBox"
                             PlaceholderText="{x:Bind SearchPlaceholderText}"
                             Margin="0,0,4,0"
                             Text="{x:Bind SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="{x:Bind EmptyResultsText}"
                               HorizontalAlignment="Left"
                               Margin="12,24,12,8"
                               Foreground="{ThemeResource TextHintColorBrush}"
                               Visibility="{x:Bind HasNoResults, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <ListView x:Name="CountryListView"
                              AutomationProperties.AutomationId="ExcludedLocationCountryListView"
                              MaxHeight="250"
                              Padding="0,0,4,0"
                              SelectionMode="None"
                              ItemTemplateSelector="{StaticResource ExcludableLocationItemTemplateSelector}"
                              Style="{StaticResource GhostListViewStyle}"
                              ItemsSource="{x:Bind LocationsSource}" />

                </StackPanel>
            </Flyout>
        </FlyoutBase.AttachedFlyout>
    </custom:GhostButton>

</UserControl>

<UserControl
    x:Class="ProtonVPN.Client.UI.Controls.DefaultConnectionSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:custom="using:ProtonVPN.Client.Common.UI.Controls.Custom"
    xmlns:pathicons="using:ProtonVPN.Client.Common.UI.Assets.Icons.PathIcons"
    xmlns:defaultConnections="using:ProtonVPN.Client.UI.Main.Settings.Pages.ConnectionPreferences"
    xmlns:selectors="using:ProtonVPN.Client.Selectors"
    x:DefaultBindMode="OneWay">

    <UserControl.Resources>
        <Style x:Key="DefaultConnectionComboItemTextBlockStyle" BasedOn="{StaticResource BodyTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="Foreground" Value="{ThemeResource TextNormColorBrush}" />
            <Setter Property="Margin" Value="0,1,0,-1" />
        </Style>

        <Style x:Key="DefaultConnectionSeparatorItemContainerStyle" TargetType="ComboBoxItem">
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Height" Value="9" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FastestConnectionItemTemplate" x:DataType="defaultConnections:DefaultConnectionItem">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <custom:SimpleCountryFlag Grid.Column="0"
                                          Width="{StaticResource MainFlagWidth}"
                                          Height="{StaticResource MainFlagHeight}"
                                          VerticalAlignment="Center"
                                          FlagType="Fastest" />

                <TextBlock Grid.Column="1"
                           Style="{StaticResource DefaultConnectionComboItemTextBlockStyle}"
                           Text="{x:Bind Header}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="RandomConnectionItemTemplate" x:DataType="defaultConnections:DefaultConnectionItem">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <custom:SimpleCountryFlag Grid.Column="0"
                                          Width="{StaticResource MainFlagWidth}"
                                          Height="{StaticResource MainFlagHeight}"
                                          VerticalAlignment="Center"
                                          FlagType="Random" />

                <TextBlock Grid.Column="1"
                           Style="{StaticResource DefaultConnectionComboItemTextBlockStyle}"
                           Text="{x:Bind Header}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="LastConnectionItemTemplate" x:DataType="defaultConnections:DefaultConnectionItem">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <custom:SimpleCountryFlag Grid.Column="0"
                                          Width="{StaticResource MainFlagWidth}"
                                          Height="{StaticResource MainFlagHeight}"
                                          VerticalAlignment="Center"
                                          FlagType="Latest" />

                <TextBlock Grid.Column="1"
                           Style="{StaticResource DefaultConnectionComboItemTextBlockStyle}"
                           Text="{x:Bind Header}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="RecentConnectionItemTemplate" x:DataType="defaultConnections:RecentDefaultConnectionItem">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="{StaticResource MainFlagWidth}">
                    <custom:ConnectionProfileIcon Width="{StaticResource MainFlagWidth}"
                                                  Height="{StaticResource MainFlagAltHeight}"
                                                  CountryCode="{x:Bind ExitCountryCode}"
                                                  FlagType="{x:Bind FlagType}"
                                                  IsFlagVisible="True"
                                                  ProfileCategory="{x:Bind Profile.Icon.Category}"
                                                  ProfileColor="{x:Bind Profile.Icon.Color}"
                                                  Visibility="{x:Bind Profile, Converter={StaticResource NotNullToVisibilityConverter}}" />
                    <custom:ComplexCountryFlag Width="{StaticResource MainFlagWidth}"
                                               Height="{StaticResource MainFlagAltHeight}"
                                               VerticalAlignment="Center"
                                               EntryCountryCode="{x:Bind EntryCountryCode}"
                                               ExitCountryCode="{x:Bind ExitCountryCode}"
                                               IsSecureCore="{x:Bind IsSecureCore}"
                                               MainFlagType="{x:Bind FlagType}"
                                               Visibility="{x:Bind Profile, Converter={StaticResource NullToVisibilityConverter}}" />
                </Grid>

                <StackPanel Grid.Column="1" Spacing="6" Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock Style="{StaticResource DefaultConnectionComboItemTextBlockStyle}"
                               Text="{x:Bind Header}" />

                    <TextBlock Style="{StaticResource DefaultConnectionComboItemTextBlockStyle}"
                               Foreground="{ThemeResource TextWeakColorBrush}"
                               Text="{x:Bind SubHeader}"
                               Visibility="{x:Bind SubHeader, Converter={StaticResource NotNullToVisibilityConverter}}" />

                    <custom:TagControl Style="{StaticResource FeatureTagControlStyle}"
                                       Text="{x:Bind Localizer.Get('Server_Feature_P2P')}"
                                       Visibility="{x:Bind IsP2P}">
                        <custom:TagControl.Icon>
                            <pathicons:ArrowRightArrowLeft Size="Pixels16" />
                        </custom:TagControl.Icon>
                    </custom:TagControl>

                    <custom:TagControl Style="{StaticResource FeatureTagControlStyle}"
                                       Text="{x:Bind Localizer.Get('Server_Feature_Tor')}"
                                       Visibility="{x:Bind IsTor}">
                        <custom:TagControl.Icon>
                            <pathicons:BrandTor Size="Pixels16" />
                        </custom:TagControl.Icon>
                    </custom:TagControl>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SeparatorItemTemplate" x:DataType="defaultConnections:DefaultConnectionSeparator">
            <Border Height="1"
                    Margin="0,4"
                    Background="{ThemeResource BorderWeakColorBrush}"
                    HorizontalAlignment="Stretch" />
        </DataTemplate>

        <selectors:DefaultConnectionItemTemplateSelector x:Key="DefaultConnectionItemTemplateSelector"
                                                         FastestConnectionItemTemplate="{StaticResource FastestConnectionItemTemplate}"
                                                         RandomConnectionItemTemplate="{StaticResource RandomConnectionItemTemplate}"
                                                         LastConnectionItemTemplate="{StaticResource LastConnectionItemTemplate}"
                                                         RecentConnectionItemTemplate="{StaticResource RecentConnectionItemTemplate}"
                                                         SeparatorItemTemplate="{StaticResource SeparatorItemTemplate}" />

        <selectors:DefaultConnectionItemContainerStyleSelector x:Key="DefaultConnectionItemContainerStyleSelector"
                                                               DefaultItemStyle="{StaticResource ComboBoxItemStyle}"
                                                               SeparatorItemStyle="{StaticResource DefaultConnectionSeparatorItemContainerStyle}" />
    </UserControl.Resources>

    <ComboBox x:Name="InternalComboBox"
              AutomationProperties.AutomationId="DefaultConnectionDropdown"
              HorizontalAlignment="Stretch"
              ItemTemplateSelector="{StaticResource DefaultConnectionItemTemplateSelector}"
              ItemContainerStyleSelector="{StaticResource DefaultConnectionItemContainerStyleSelector}"
              Style="{StaticResource ComboBoxStyle}" />
</UserControl>
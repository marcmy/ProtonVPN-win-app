<UserControl x:Class="ProtonVPN.Client.UI.Main.Home.Card.DefaultConnections.DefaultConnectionSelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:custom="using:ProtonVPN.Client.Common.UI.Controls.Custom"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pathicons="using:ProtonVPN.Client.Common.UI.Assets.Icons.PathIcons"
             xmlns:controls="using:ProtonVPN.Client.UI.Controls"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">
    <Grid>
        <controls:DefaultConnectionSelector x:Name="ConnectionSelector"
                                            Opacity="0"
                                            IsHitTestVisible="False"
                                            MinWidth="300"
                                            ItemsSource="{x:Bind ViewModel.ConnectionsList}"
                                            SelectedItem="{x:Bind ViewModel.SelectedDefaultConnection, Mode=TwoWay}"/>
        <custom:GhostButton x:Name="FlyoutButton" 
                            Click="FlyoutButton_OnClick"
                            AutomationProperties.AutomationId="DefaultConnectionSelectorButton">
            <custom:GhostButton.LeftIcon>
                <pathicons:ChevronDownFilled />
            </custom:GhostButton.LeftIcon>
        </custom:GhostButton>
    </Grid>
</UserControl>
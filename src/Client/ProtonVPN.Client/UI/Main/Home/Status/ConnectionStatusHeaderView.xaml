<UserControl x:Class="ProtonVPN.Client.UI.Main.Home.Status.ConnectionStatusHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:commonControls="using:ProtonVPN.Client.Common.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:ProtonVPN.Client.UI.Main.Home.Status"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pathIcons="using:ProtonVPN.Client.Common.UI.Assets.Icons.PathIcons"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <StackPanel Spacing="6">

        <Grid Visibility="{x:Bind UseSimplifiedVersion, Converter={StaticResource NotBooleanToVisibilityConverter}}">

            <Border x:Name="CurrentServerHealthPanel"
                    MaxWidth="660"
                    Padding="12,8"
                    HorizontalAlignment="Center"
                    Background="{ThemeResource BackgroundNormColorBrush}"
                    BorderBrush="{ThemeResource BorderWeakColorBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{x:Bind ViewModel.IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">

                <ToolTipService.ToolTip>
                    <ToolTip Placement="Top">
                        <commonControls:ServerHealthHistoryDetailsControl
                            Snapshot="{x:Bind ViewModel.CurrentServerHealthSnapshot, Mode=OneWay}" />
                    </ToolTip>
                </ToolTipService.ToolTip>

                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   Text="Current server health" />

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextWeakColorBrush}"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   Text="{x:Bind ViewModel.CurrentServerName}"
                                   TextTrimming="CharacterEllipsis" />

                        <Border x:Name="HealthGradePill"
                                Grid.Column="2"
                                Padding="7,2"
                                Background="{ThemeResource BackgroundWeakColorBrush}"
                                CornerRadius="7">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4">
                                <ProgressRing x:Name="HealthRefreshSpinner"
                                              Width="10"
                                              Height="10"
                                              IsActive="False"
                                              Visibility="Collapsed" />
                                <TextBlock x:Name="HealthGradeText"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextWeakColorBrush}"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           Text="{x:Bind ViewModel.HealthGrade}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Height="25"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="2">
                            <Border x:Name="HealthBar1"
                                    Width="5"
                                    Height="7"
                                    VerticalAlignment="Bottom"
                                    Background="{ThemeResource TextWeakColorBrush}"
                                    CornerRadius="1"
                                    Opacity="0.2" />
                            <Border x:Name="HealthBar2"
                                    Width="5"
                                    Height="12"
                                    VerticalAlignment="Bottom"
                                    Background="{ThemeResource TextWeakColorBrush}"
                                    CornerRadius="1"
                                    Opacity="0.2" />
                            <Border x:Name="HealthBar3"
                                    Width="5"
                                    Height="18"
                                    VerticalAlignment="Bottom"
                                    Background="{ThemeResource TextWeakColorBrush}"
                                    CornerRadius="1"
                                    Opacity="0.2" />
                            <Border x:Name="HealthBar4"
                                    Width="5"
                                    Height="24"
                                    VerticalAlignment="Bottom"
                                    Background="{ThemeResource TextWeakColorBrush}"
                                    CornerRadius="1"
                                    Opacity="0.2" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="0">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{x:Bind ViewModel.HealthLatency}" />
                            <TextBlock FontSize="12"
                                       Foreground="{ThemeResource TextWeakColorBrush}"
                                       Text="Latency" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    MinWidth="66"
                                    VerticalAlignment="Center"
                                    Spacing="0">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       Text="{x:Bind ViewModel.HealthPacketLoss}" />
                            <TextBlock FontSize="12"
                                       Foreground="{ThemeResource TextWeakColorBrush}"
                                       Text="Packet loss" />
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                                    MinWidth="44"
                                    VerticalAlignment="Center"
                                    Spacing="0">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       Text="{x:Bind ViewModel.HealthLoad}" />
                            <TextBlock FontSize="12"
                                       Foreground="{ThemeResource TextWeakColorBrush}"
                                       Text="Load" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextWeakColorBrush}"
                                   Text="{x:Bind ViewModel.HealthRoute}"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Column="1"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextWeakColorBrush}"
                                   Text="{x:Bind ViewModel.HealthLastChecked}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="0,-2,0,2">

                <ProgressRing x:Name="LoadingSpinner"
                              Width="20"
                              Height="20"
                              IsActive="False" />

                <pathIcons:LockOpenFilled2 x:Name="UnprotectedIcon"
                                           Foreground="{ThemeResource SignalDangerColorBrush}"
                                           Visibility="Collapsed" />

                <pathIcons:LockFilled x:Name="ProtectedIcon"
                                      Foreground="{ThemeResource VpnGreenColorBrush}"
                                      Visibility="Collapsed" />

                <Image x:Name="NoWiFiIcon"
                       Width="22"
                       Height="20"
                       Source="{StaticResource NoWiFiIconSource}"
                       Visibility="Collapsed" />

            </Grid>

            <TextBlock x:Name="ProtectionTitle"
                       Grid.Row="0"
                       Grid.Column="1"
                       AutomationProperties.AutomationId="ProtectionTitle"
                       AutomationProperties.Name="{x:Bind ViewModel.ProtectionTitle}"
                       Foreground="{ThemeResource TextNormColorBrush}"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       Text="{x:Bind ViewModel.ProtectionTitle}" />

            <TextBlock x:Name="ProtectionDescription"
                       Grid.Row="0"
                       Grid.Column="2"
                       AutomationProperties.AutomationId="ProtectionDescription"
                       AutomationProperties.Name="{x:Bind ViewModel.ProtectionDescription}"
                       Foreground="{ThemeResource TextWeakColorBrush}"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       Visibility="{x:Bind UseSimplifiedVersion, Converter={StaticResource NotBooleanToVisibilityConverter}}">
                <Run Text="• " />
                <Run Text="{x:Bind ViewModel.ProtectionDescription}" />
            </TextBlock>
        </Grid>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ConnectionStates">

                <VisualState x:Name="IsInternetUnavailable">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsInternetUnavailable}" />
                        <StateTrigger IsActive="{x:Bind ViewModel.IsTwoFactorRequired}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ProtectionTitle.Foreground" Value="{ThemeResource SignalWarningColorBrush}" />
                        <Setter Target="NoWiFiIcon.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Connecting">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsConnecting}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="LoadingSpinner.IsActive" Value="True" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Disconnected">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsDisconnected}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ProtectionTitle.Foreground" Value="{ThemeResource SignalDangerColorBrush}" />
                        <Setter Target="UnprotectedIcon.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Connected">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsConnected}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ProtectionTitle.Foreground" Value="{ThemeResource VpnGreenColorBrush}" />
                        <Setter Target="ProtectedIcon.Visibility" Value="Visible" />
                        <Setter Target="ProtectionDescription.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Default" />

            </VisualStateGroup>

            <VisualStateGroup x:Name="HealthStates">
                <VisualState x:Name="HealthChecking">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsHealthChecking}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HealthRefreshSpinner.IsActive" Value="True" />
                        <Setter Target="HealthRefreshSpinner.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="HealthUnavailable">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsHealthUnavailable}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HealthGradeText.Foreground" Value="{ThemeResource TextWeakColorBrush}" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="HealthPoor">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsHealthPoor}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HealthGradeText.Foreground" Value="{ThemeResource SignalDangerColorBrush}" />
                        <Setter Target="HealthBar1.Background" Value="{ThemeResource SignalDangerColorBrush}" />
                        <Setter Target="HealthBar1.Opacity" Value="1" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="HealthFair">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsHealthFair}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HealthGradeText.Foreground" Value="{ThemeResource SignalWarningColorBrush}" />
                        <Setter Target="HealthBar1.Background" Value="{ThemeResource SignalWarningColorBrush}" />
                        <Setter Target="HealthBar2.Background" Value="{ThemeResource SignalWarningColorBrush}" />
                        <Setter Target="HealthBar1.Opacity" Value="1" />
                        <Setter Target="HealthBar2.Opacity" Value="1" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="HealthGood">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsHealthGood}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HealthGradeText.Foreground" Value="{ThemeResource SignalSuccessColorBrush}" />
                        <Setter Target="HealthBar1.Background" Value="{ThemeResource SignalSuccessColorBrush}" />
                        <Setter Target="HealthBar2.Background" Value="{ThemeResource SignalSuccessColorBrush}" />
                        <Setter Target="HealthBar3.Background" Value="{ThemeResource SignalSuccessColorBrush}" />
                        <Setter Target="HealthBar1.Opacity" Value="1" />
                        <Setter Target="HealthBar2.Opacity" Value="1" />
                        <Setter Target="HealthBar3.Opacity" Value="1" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="HealthExcellent">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind ViewModel.IsHealthExcellent}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HealthGradeText.Foreground" Value="{ThemeResource SignalSuccessColorBrush}" />
                        <Setter Target="HealthBar1.Background" Value="{ThemeResource SignalSuccessColorBrush}" />
                        <Setter Target="HealthBar2.Background" Value="{ThemeResource SignalSuccessColorBrush}" />
                        <Setter Target="HealthBar3.Background" Value="{ThemeResource SignalSuccessColorBrush}" />
                        <Setter Target="HealthBar4.Background" Value="{ThemeResource SignalSuccessColorBrush}" />
                        <Setter Target="HealthBar1.Opacity" Value="1" />
                        <Setter Target="HealthBar2.Opacity" Value="1" />
                        <Setter Target="HealthBar3.Opacity" Value="1" />
                        <Setter Target="HealthBar4.Opacity" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </StackPanel>

</UserControl>

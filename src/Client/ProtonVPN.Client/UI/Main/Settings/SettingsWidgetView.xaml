<UserControl x:Class="ProtonVPN.Client.UI.Main.Settings.SettingsWidgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:custom="using:ProtonVPN.Client.Common.UI.Controls.Custom"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pathicons="using:ProtonVPN.Client.Common.UI.Assets.Icons.PathIcons"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <custom:WidgetButton x:Name="SettingsButton"
                         AutomationProperties.AutomationId="SettingsButton"
                         Command="{x:Bind ViewModel.InvokeCommand, Mode=OneTime}"
                         Text="{x:Bind ViewModel.Header}"
                         IsActive="{x:Bind ViewModel.IsSelected}"
                         Style="{StaticResource SideWidgetButtonStyle}"
                         ToolTipService.ToolTip="Ctrl + ,"
                         Visibility="{x:Bind ViewModel.IsAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
        <custom:WidgetButton.Resources>
            <TeachingTip x:Name="ExcludedLocationsTeachingTip"
                         Target="{x:Bind SettingsButton}"
                         Title="{x:Bind ViewModel.Localizer.Get('ExcludedLocations_TeachingTip_Title')}"
                         Subtitle="{x:Bind ViewModel.Localizer.Get('ExcludedLocations_TeachingTip_Subtitle')}"
                         IsOpen="{x:Bind ViewModel.IsExcludedLocationsTeachingTipOpen, Mode=TwoWay}"
                         ActionButtonContent="{x:Bind ViewModel.Localizer.Get('ExcludedLocations_TeachingTip_ActionButton')}"
                         ActionButtonCommand="{x:Bind ViewModel.InvokeTeachingTipActionCommand, Mode=OneTime}"
                         CloseButtonContent="{x:Bind ViewModel.Localizer.Get('ExcludedLocations_TeachingTip_CloseButton')}"
                         CloseButtonCommand="{x:Bind ViewModel.DismissTeachingTipCommand, Mode=OneTime}"
                         Style="{StaticResource DefaultTeachingTipStyle}"
                         PreferredPlacement="Left"
                         PlacementMargin="4"
                         IsLightDismissEnabled="False">
                <TeachingTip.HeroContent>
                    <Image Grid.Row="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Source="{StaticResource ExcludedLocationsTootTipIllustrationSource}"
                           Stretch="Uniform" />
                </TeachingTip.HeroContent>
            </TeachingTip>
        </custom:WidgetButton.Resources>

        <Image Source="{ThemeResource SettingsIllustrationSource}"
               Width="{StaticResource FeatureBarDimmableImageSize}"
               Height="{StaticResource FeatureBarDimmableImageSize}" />
    </custom:WidgetButton>

</UserControl>